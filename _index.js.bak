#!/usr/bin/env node

const http = require('http');
const WebSocket = require('ws');
const net = require('net');
const dgram = require('dgram');
const url = require('url');
const axios = require('axios');
const os = require('os');
const fs = require('fs');
const path = require('path');
const { promisify } = require('util');
const exec = promisify(require('child_process').exec);

// ==================== ENVIRONMENT VARIABLES ====================
const FILE_PATH = process.env.FILE_PATH || '.tmp';
const PORT = process.env.PORT || 3000;
const UUID = process.env.UUID || '9afd1229-b893-40c1-84dd-51e7ce204913';
const ARGO_DOMAIN = process.env.ARGO_DOMAIN || '';
const ARGO_AUTH = process.env.ARGO_AUTH || '';
const ARGO_PORT = process.env.ARGO_PORT || 8001;
const CFIP = process.env.CFIP || 'bug.com';
const CFPORT = process.env.CFPORT || 443;
const NAME = process.env.NAME || 'BLUEHAT358';
const SSH_USER = process.env.SSH_USER || 'root';
const SSH_PASS = process.env.SSH_PASS || 'BlueHat358';

// ==================== GLOBAL CONSTANTS ====================
const horse = Buffer.from("dHJvamFu", 'base64').toString();
const flash = Buffer.from("dm1lc3M=", 'base64').toString();
const WS_READY_STATE_OPEN = 1;

let argoConfigs = { vless: '', vmess: '', trojan: '', vless_grpc: '', vmess_grpc: '', trojan_grpc: '', ssh: '' };
const generateRandomName = () => Math.random().toString(36).substring(2, 8);
const webName = generateRandomName();
const botName = generateRandomName();
const webPath = path.join(FILE_PATH, webName);
const botPath = path.join(FILE_PATH, botName);
const subFilePath = path.join(FILE_PATH, 'sub.txt');
const bootLogPath = path.join(FILE_PATH, 'boot.log');

// ==================== BACKGROUND SERVICES ====================
if (!fs.existsSync(FILE_PATH)) fs.mkdirSync(FILE_PATH, { recursive: true });

async function generateXrayConfig() {
  const config = {
    log: { access: '/dev/null', error: '/dev/null', loglevel: 'none' },
    inbounds: [
      // Main TCP inbound with fallbacks (WS + gRPC)
      {
        port: ARGO_PORT, protocol: 'vless',
        settings: {
          clients: [{ id: UUID, flow: 'xtls-rprx-vision' }],
          decryption: 'none',
          fallbacks: [
            { dest: 3001 },
            { path: "/vless-BlueHat358", dest: 3002 },
            { path: "/vmess-BlueHat358", dest: 3003 },
            { path: "/trojan-BlueHat358", dest: 3004 },
            { path: "/ssh-BlueHat358", dest: 2222 },
          ]
        },
        streamSettings: { network: 'tcp' }
      },
      // WS inbounds
      { port: 3001, listen: "127.0.0.1", protocol: "vless", settings: { clients: [{ id: UUID }], decryption: "none" }, streamSettings: { network: "tcp", security: "none" } },
      { port: 3002, listen: "127.0.0.1", protocol: "vless", settings: { clients: [{ id: UUID, level: 0 }], decryption: "none" }, streamSettings: { network: "ws", security: "none", wsSettings: { path: "/vless-BlueHat358" } }, sniffing: { enabled: true, destOverride: ["http", "tls", "quic"], metadataOnly: false } },
      { port: 3003, listen: "127.0.0.1", protocol: "vmess", settings: { clients: [{ id: UUID, alterId: 0 }] }, streamSettings: { network: "ws", wsSettings: { path: "/vmess-BlueHat358" } }, sniffing: { enabled: true, destOverride: ["http", "tls", "quic"], metadataOnly: false } },
      { port: 3004, listen: "127.0.0.1", protocol: "trojan", settings: { clients: [{ password: UUID }] }, streamSettings: { network: "ws", security: "none", wsSettings: { path: "/trojan-BlueHat358" } }, sniffing: { enabled: true, destOverride: ["http", "tls", "quic"], metadataOnly: false } },
      // gRPC inbounds
      { port: 3005, listen: "127.0.0.1", protocol: "vless", settings: { clients: [{ id: UUID, level: 0 }], decryption: "none" }, streamSettings: { network: "grpc", security: "none", grpcSettings: { serviceName: "vless-grpc-BlueHat358" } }, sniffing: { enabled: true, destOverride: ["http", "tls", "quic"], metadataOnly: false } },
      { port: 3006, listen: "127.0.0.1", protocol: "vmess", settings: { clients: [{ id: UUID, alterId: 0 }] }, streamSettings: { network: "grpc", grpcSettings: { serviceName: "vmess-grpc-BlueHat358" } }, sniffing: { enabled: true, destOverride: ["http", "tls", "quic"], metadataOnly: false } },
      { port: 3007, listen: "127.0.0.1", protocol: "trojan", settings: { clients: [{ password: UUID }] }, streamSettings: { network: "grpc", security: "none", grpcSettings: { serviceName: "trojan-grpc-BlueHat358" } }, sniffing: { enabled: true, destOverride: ["http", "tls", "quic"], metadataOnly: false } },
    ],
    dns: { servers: ["https+local://8.8.8.8/dns-query"] },
    outbounds: [{ protocol: "freedom", tag: "direct" }, { protocol: "blackhole", tag: "block" }]
  };
  fs.writeFileSync(path.join(FILE_PATH, 'config.json'), JSON.stringify(config, null, 2));
}

// ==================== SSH SERVER SETUP ====================
async function setupSSHServer() {
  try {
    // Install openssh-server jika belum ada
    await exec('which sshd').catch(async () => {
      console.log('[SSH] Installing OpenSSH server...');
      await exec('apt-get update -qq && apt-get install -y openssh-server -qq');
    });

    // Buat direktori SSH
    await exec('mkdir -p /var/run/sshd /root/.ssh');
    await exec('chmod 700 /root/.ssh');

    // Set password user
    await exec(`echo "${SSH_USER}:${SSH_PASS}" | chpasswd`).catch(() => {});

    // Konfigurasi sshd
    const sshdConfig = `
Port 22
PermitRootLogin yes
PasswordAuthentication yes
PubkeyAuthentication yes
AuthorizedKeysFile .ssh/authorized_keys
X11Forwarding no
PrintMotd no
AcceptEnv LANG LC_*
Subsystem sftp /usr/lib/openssh/sftp-server
UsePAM yes
`;
    fs.writeFileSync('/etc/ssh/sshd_config', sshdConfig);

    // Generate host keys jika belum ada
    await exec('ssh-keygen -A').catch(() => {});

    // Start sshd
    await exec('service ssh start || /usr/sbin/sshd');
    console.log('[SSH] OpenSSH Server Started on port 22');
    console.log(`[SSH] Login: ${SSH_USER} / ${SSH_PASS}`);
  } catch (err) {
    console.error('[SSH] Setup error:', err.message);
  }
}

// ==================== gRPC PROXY (Node.js layer) ====================
// gRPC dari Argo diteruskan ke xray port 3005/3006/3007
function startGrpcProxy() {
  // Node.js HTTP/2 proxy untuk gRPC — meneruskan koneksi gRPC ke xray internal
  const grpcRoutes = {
    '/vless-grpc-BlueHat358': 3005,
    '/vmess-grpc-BlueHat358': 3006,
    '/trojan-grpc-BlueHat358': 3007,
  };

  // Tangani HTTP/2 upgrade untuk gRPC via CONNECT tunnel ke xray
  // Ini dihandle di level TCP proxy agar binary-safe
  const grpcProxyServer = net.createServer((clientSocket) => {
    let buffer = Buffer.alloc(0);
    let targetPort = null;
    let targetSocket = null;

    clientSocket.on('data', (chunk) => {
      buffer = Buffer.concat([buffer, chunk]);

      if (!targetPort) {
        const header = buffer.toString('utf8', 0, Math.min(buffer.length, 512));
        for (const [path, port] of Object.entries(grpcRoutes)) {
          if (header.includes(path)) {
            targetPort = port;
            break;
          }
        }
        if (!targetPort) targetPort = 3005; // default vless grpc

        targetSocket = net.createConnection({ host: '127.0.0.1', port: targetPort }, () => {
          targetSocket.write(buffer);
          buffer = null;
        });

        targetSocket.on('data', (d) => { if (clientSocket.writable) clientSocket.write(d); });
        targetSocket.on('close', () => clientSocket.destroy());
        targetSocket.on('error', () => clientSocket.destroy());
        clientSocket.on('close', () => targetSocket.destroy());
        clientSocket.on('error', () => targetSocket.destroy());
      } else if (targetSocket && targetSocket.writable) {
        targetSocket.write(chunk);
        buffer = null;
      }
    });
  });

  grpcProxyServer.listen(3008, '127.0.0.1', () => {
    console.log('[gRPC] Proxy layer active on 127.0.0.1:3008');
  });
}

function downloadFile(fileUrl, filePath) {
  return new Promise((resolve, reject) => {
    const writer = fs.createWriteStream(filePath);
    axios({ method: 'get', url: fileUrl, responseType: 'stream' })
      .then(response => {
        response.data.pipe(writer);
        writer.on('finish', () => resolve(filePath));
        writer.on('error', reject);
      }).catch(reject);
  });
}

async function startBackgroundServices() {
  const arch = os.arch() === 'arm' || os.arch() === 'arm64' || os.arch() === 'aarch64' ? 'arm64' : 'amd64';
  const baseUrl = `https://${arch}.ssss.nyc.mn`;

  await generateXrayConfig();

  // Setup SSH terlebih dahulu
  await setupSSHServer();

  try {
    await Promise.all([
      downloadFile(`${baseUrl}/web`, webPath),
      downloadFile(`${baseUrl}/bot`, botPath)
    ]);

    fs.chmodSync(webPath, 0o775);
    fs.chmodSync(botPath, 0o775);

    exec(`nohup ${webPath} -c ${FILE_PATH}/config.json >/dev/null 2>&1 &`);
    console.log('[SYSTEM] Xray Engine Started');

    // Start gRPC proxy layer
    startGrpcProxy();

    let tunnelArgs = `tunnel --edge-ip-version auto --no-autoupdate --protocol http2 --logfile ${bootLogPath} --loglevel info --url http://localhost:${ARGO_PORT}`;
    if (ARGO_AUTH && ARGO_AUTH.match(/^[A-Z0-9a-z=]{120,250}$/)) {
      tunnelArgs = `tunnel --edge-ip-version auto --no-autoupdate --protocol http2 run --token ${ARGO_AUTH}`;
    }

    exec(`nohup ${botPath} ${tunnelArgs} >/dev/null 2>&1 &`);
    console.log('[SYSTEM] Tunnel Bot Started');

    setTimeout(extractDomains, 5000);
  } catch (err) {
    console.error('[SYSTEM] Background service error:', err.message);
  }
}

async function extractDomains() {
  if (ARGO_AUTH && ARGO_DOMAIN) {
    await generateLinks(ARGO_DOMAIN);
    return;
  }
  try {
    const logData = fs.readFileSync(bootLogPath, 'utf-8');
    const match = logData.match(/https?:\/\/([^ ]*trycloudflare\.com)\/?/);
    if (match) {
      console.log('[SYSTEM] Argo Tunnel Extracted:', match[1]);
      await generateLinks(match[1]);
    } else {
      setTimeout(extractDomains, 3000);
    }
  } catch (e) {
    setTimeout(extractDomains, 3000);
  }
}

async function generateLinks(domain) {
  const fp = 'firefox';

  // VMess WS
  const vmessObj = { v: '2', ps: `${NAME}-CDN-VMESS`, add: CFIP, port: CFPORT, id: UUID, aid: '0', scy: 'auto', net: 'ws', type: 'none', host: domain, path: '/vmess-BlueHat358', tls: 'tls', sni: domain, alpn: '', fp };
  // VMess gRPC
  const vmessGrpcObj = { v: '2', ps: `${NAME}-CDN-VMESS-gRPC`, add: domain, port: 443, id: UUID, aid: '0', scy: 'auto', net: 'grpc', type: 'gun', host: domain, path: 'vmess-grpc-BlueHat358', tls: 'tls', sni: domain, alpn: '', fp };

  // WS configs
  argoConfigs.vless  = `vless://${UUID}@${CFIP}:${CFPORT}?encryption=none&security=tls&sni=${domain}&fp=${fp}&type=ws&host=${domain}&path=%2Fvless-BlueHat358#${NAME}-CDN-VLESS`;
  argoConfigs.vmess  = `vmess://${Buffer.from(JSON.stringify(vmessObj)).toString('base64')}`;
  argoConfigs.trojan = `trojan://${UUID}@${CFIP}:${CFPORT}?security=tls&sni=${domain}&fp=${fp}&type=ws&host=${domain}&path=%2Ftrojan-BlueHat358#${NAME}-CDN-TROJAN`;

  // gRPC configs — langsung ke domain Argo (tanpa CFIP, karena gRPC tidak bisa via CF CDN IP)
  argoConfigs.vless_grpc  = `vless://${UUID}@${domain}:443?encryption=none&security=tls&sni=${domain}&fp=${fp}&type=grpc&serviceName=vless-grpc-BlueHat358&mode=gun#${NAME}-CDN-VLESS-gRPC`;
  argoConfigs.vmess_grpc  = `vmess://${Buffer.from(JSON.stringify(vmessGrpcObj)).toString('base64')}`;
  argoConfigs.trojan_grpc = `trojan://${UUID}@${domain}:443?security=tls&sni=${domain}&fp=${fp}&type=grpc&serviceName=trojan-grpc-BlueHat358&mode=gun#${NAME}-CDN-TROJAN-gRPC`;

  // SSH via WebSocket
  argoConfigs.ssh = `Host: ${domain}\nPort: 443 (WebSocket)\nPath: /ssh-BlueHat358\nUser: ${SSH_USER}\nPass: ${SSH_PASS}\n\n# SSH Config:\nHost ${NAME}-ssh\n  HostName ${domain}\n  User ${SSH_USER}\n  ProxyCommand websocat - wss://${domain}/ssh-BlueHat358`;

  const subTxt = [
    argoConfigs.vless,
    argoConfigs.vmess,
    argoConfigs.trojan,
    argoConfigs.vless_grpc,
    argoConfigs.vmess_grpc,
    argoConfigs.trojan_grpc,
  ].join('\n');
  fs.writeFileSync(subFilePath, subTxt);
  console.log('[SYSTEM] All subscriptions generated (WS + gRPC + SSH).');
}

// ==================== HYBRID GATEWAY SERVER ====================
class HybridServer {
  constructor() {
    this.wss = null;
    this.httpServer = null;
    this.activeUDPConnections = new Map();
    this.stats = { rx: 0, tx: 0 };
    this.lastCpu = null;
  }

  async handleHttpRequest(req, res) {
    const parsedUrl = url.parse(req.url, true);

    // API Statistik
    if (parsedUrl.pathname === '/api/stats') {
      let currentRx = this.stats.rx;
      let currentTx = this.stats.tx;

      try {
        if (fs.existsSync('/proc/net/dev')) {
          const devData = fs.readFileSync('/proc/net/dev', 'utf-8');
          const lines = devData.split('\n');
          let sysRx = 0, sysTx = 0;
          for (let i = 2; i < lines.length; i++) {
            const line = lines[i].trim();
            if (!line || line.startsWith('lo:')) continue;
            const parts = line.split(/:?\s+/);
            if (parts.length > 9) {
              sysRx += parseInt(parts[1] || 0, 10);
              sysTx += parseInt(parts[9] || 0, 10);
            }
          }
          if (sysRx > 0 || sysTx > 0) { currentRx = sysRx; currentTx = sysTx; }
        }
      } catch (e) {}

      const cpus = os.cpus();
      let user = 0, nice = 0, sys = 0, idle = 0, irq = 0;
      for (let cpu in cpus) {
        user += cpus[cpu].times.user; nice += cpus[cpu].times.nice;
        sys += cpus[cpu].times.sys; idle += cpus[cpu].times.idle;
        irq += cpus[cpu].times.irq;
      }
      const totalCpu = user + nice + sys + idle + irq;
      if (!this.lastCpu) this.lastCpu = { idle, total: totalCpu };
      const idleDelta = idle - this.lastCpu.idle;
      const totalDelta = totalCpu - this.lastCpu.total;
      const cpuUsage = totalDelta === 0 ? 0 : (100 - (100 * idleDelta / totalDelta)).toFixed(1);
      this.lastCpu = { idle, total: totalCpu };

      const totalMem = os.totalmem();
      const freeMem = os.freemem();
      const ramUsage = ((totalMem - freeMem) / totalMem * 100).toFixed(1);

      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({
        uptime: Math.floor(process.uptime()),
        rx: currentRx, tx: currentTx,
        cpu: parseFloat(cpuUsage),
        ram: parseFloat(ramUsage)
      }));
      return;
    }

    // API Config
    if (parsedUrl.pathname === '/api/config') {
      const host = req.headers.host;
      const fp = 'firefox';
      const payload = {
        native: {
          vless: `vless://${UUID}@${host}:443?encryption=none&security=tls&sni=${host}&fp=${fp}&type=ws&host=${host}&path=%2Fvless-BlueHat358#${NAME}-SNI-VLESS`,
          vmess: `vmess://${Buffer.from(JSON.stringify({ v: '2', ps: `${NAME}-SNI-VMESS`, add: host, port: 443, id: UUID, aid: '0', scy: 'auto', net: 'ws', type: 'none', host: host, path: '/vmess-BlueHat358', tls: 'tls', sni: host, alpn: '', fp })).toString('base64')}`,
          trojan: `trojan://${UUID}@${host}:443?security=tls&sni=${host}&fp=${fp}&type=ws&host=${host}&path=%2Ftrojan-BlueHat358#${NAME}-SNI-TROJAN`,
          vless_grpc: `vless://${UUID}@${host}:443?encryption=none&security=tls&sni=${host}&fp=${fp}&type=grpc&serviceName=vless-grpc-BlueHat358&mode=gun#${NAME}-SNI-VLESS-gRPC`,
          vmess_grpc: `vmess://${Buffer.from(JSON.stringify({ v: '2', ps: `${NAME}-SNI-VMESS-gRPC`, add: host, port: 443, id: UUID, aid: '0', scy: 'auto', net: 'grpc', type: 'gun', host: host, path: 'vmess-grpc-BlueHat358', tls: 'tls', sni: host, alpn: '', fp })).toString('base64')}`,
          trojan_grpc: `trojan://${UUID}@${host}:443?security=tls&sni=${host}&fp=${fp}&type=grpc&serviceName=trojan-grpc-BlueHat358&mode=gun#${NAME}-SNI-TROJAN-gRPC`,
          ssh: `Host: ${host}\nPort: 443 (WebSocket/TLS)\nPath: /ssh-BlueHat358\nUser: ${SSH_USER}\nPass: ${SSH_PASS}\n\n# SSH Config (websocat):\nHost ${NAME}-ssh-sni\n  HostName ${host}\n  User ${SSH_USER}\n  ProxyCommand websocat - wss://${host}/ssh-BlueHat358\n\n# Payload HTTP Injector / HTTP Custom:\nServer  : ${host}\nPort    : 443\nPath    : /ssh-BlueHat358\nSSL/TLS : ON\n\n# Payload PATCH (WebSocket Upgrade):\nPATCH /ssh-BlueHat358 HTTP/1.1[crlf]Host: ${host}[crlf]Upgrade: websocket[crlf]Connection: Upgrade[crlf]User-Agent: [ua][crlf][crlf]`,
        },
        argo: {
          vless: argoConfigs.vless || 'Menunggu Argo Tunnel...',
          vmess: argoConfigs.vmess || 'Menunggu Argo Tunnel...',
          trojan: argoConfigs.trojan || 'Menunggu Argo Tunnel...',
          vless_grpc: argoConfigs.vless_grpc || 'Menunggu Argo Tunnel...',
          vmess_grpc: argoConfigs.vmess_grpc || 'Menunggu Argo Tunnel...',
          trojan_grpc: argoConfigs.trojan_grpc || 'Menunggu Argo Tunnel...',
          ssh: argoConfigs.ssh || 'Menunggu Argo Tunnel...',
        }
      };
      res.writeHead(200, { 'Content-Type': 'application/json; charset=utf-8' });
      return res.end(JSON.stringify(payload));
    }

    // Dashboard UI
    if (parsedUrl.pathname === '/') {
      res.writeHead(200, { 'Content-Type': 'text/html' });
      res.end(`<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GATEWAY CORE</title>
  <style>
    :root {
      --bg-black: #000000; --panel-bg: #0a0a0a; --card-bg: #050505;
      --border-color: #1f1f1f; --border-hover: #333333;
      --text-main: #ffffff; --text-muted: #888888;
      --accent-blue: #0088FF; --accent-cyan: #00ffff;
      --accent-purple: #a855f7; --accent-pink: #ff0080;
      --accent-green: #22c55e; --accent-orange: #f97316;
      --status-green: #00df89; --status-red: #ff5f56;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background-color: var(--bg-black); color: var(--text-main); font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; min-height: 100vh; display: flex; flex-direction: column; align-items: center; padding: 6vh 24px; }
    .window-container { width: 100%; max-width: 720px; background-color: var(--panel-bg); border: 1px solid var(--border-color); border-radius: 12px; box-shadow: 0 30px 60px rgba(0,0,0,.8); overflow: hidden; }
    .window-header { background-color: var(--card-bg); border-bottom: 1px solid var(--border-color); padding: 14px 20px; display: flex; align-items: center; justify-content: space-between; }
    .mac-dots { display: flex; gap: 8px; }
    .dot { width: 12px; height: 12px; border-radius: 50%; opacity: .75; }
    .dot.close { background-color: #ff5f56; } .dot.minimize { background-color: #ffbd2e; } .dot.zoom { background-color: #27c93f; }
    .brand-title { font-size: .8rem; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; }
    .brand-media { color: #fff; } .brand-fairy { color: var(--accent-blue); }
    .status-badge { display: flex; align-items: center; gap: 6px; font-size: .75rem; font-weight: 600; color: var(--status-green); }
    .pulse-dot { width: 6px; height: 6px; background-color: var(--status-green); border-radius: 50%; box-shadow: 0 0 8px var(--status-green); animation: ambientPulse 2.5s infinite ease-in-out; }
    .window-content { padding: 32px; }
    .uptime-section { text-align: center; padding-bottom: 24px; border-bottom: 1px solid var(--border-color); margin-bottom: 24px; }
    .section-label { font-size: .65rem; text-transform: uppercase; color: var(--text-muted); letter-spacing: 2px; margin-bottom: 6px; }
    .uptime-display { font-size: 2.5rem; font-weight: 800; letter-spacing: -1px; font-variant-numeric: tabular-nums; }
    .stats-grid { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 16px; margin-bottom: 24px; }
    .card { background-color: var(--card-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 16px; position: relative; overflow: hidden; }
    .card-value { font-size: 1.25rem; font-weight: 700; margin-top: 4px; font-variant-numeric: tabular-nums; }
    .live-speed { font-size: .75rem; font-family: monospace; font-weight: 600; margin-top: 6px; }
    .live-speed.down { color: var(--status-green); } .live-speed.up { color: var(--accent-blue); }
    .resource-bar { width: 100%; height: 3px; background-color: #222; position: absolute; bottom: 0; left: 0; }
    .resource-fill { height: 100%; background-color: var(--accent-cyan); transition: width 1s ease; }
    .chart-card { background-color: var(--card-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 16px; margin-bottom: 28px; }
    .chart-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
    .legend { display: flex; gap: 12px; font-size: .7rem; color: var(--text-muted); font-weight: 600; }
    .legend-item { display: flex; align-items: center; gap: 4px; }
